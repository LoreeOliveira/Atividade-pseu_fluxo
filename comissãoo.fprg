    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="comissao, produto" type="Real" array="False" size=""/>
            <output expression="&quot;digite o valor do produto&quot;" newline="True"/>
            <input variable="produto"/>
            <if expression="produto &lt;=5000">
                <then>
                    <assign variable="comissao" expression="produto * 0.05"/>
                    <output expression="(&quot;sua comissao foi de &quot; &amp; comissao)" newline="True"/>
                </then>
                <else>
                    <assign variable="comissao" expression="produto * 0.10"/>
                    <output expression="(&quot;sua comissao foi de &quot; &amp; comissao)" newline="True"/>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
